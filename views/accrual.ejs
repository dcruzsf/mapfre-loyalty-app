<%- include('partials/header', {currentPage: 'accrual'}) %>

<div class="container">
  <div class="page-header-space text-center mt-5 mb-5">
    <h1 class="page-title" style="color: #d81e05; font-weight: 800; font-size: 2.5rem; text-transform: uppercase;">Club MAPFRE</h1>
    <p class="lead text-muted">Suma tréboles con tus compras diarias y ahorra en tus seguros</p>
  </div>

  <div class="row justify-content-center mb-5">
    <div class="col-md-10">
      <div class="card shadow-lg border-0" style="border-radius: 20px; background: linear-gradient(135deg, #d81e05 0%, #a31604 100%); color: white;">
        <div class="card-body p-5">
          <div class="row text-center align-items-center">
            <div class="col-md-4 mb-3 mb-md-0 border-md-right" style="border-color: rgba(255,255,255,0.2) !important;">
              <small style="text-transform: uppercase; letter-spacing: 2px; font-weight: 600; opacity: 0.8;">Puntos Nivel</small>
              <h2 class="display-4 mb-0" style="font-weight: 700;"><%= member.levelPoints %></h2>
            </div>
            <div class="col-md-4 mb-3 mb-md-0 border-md-right" style="border-color: rgba(255,255,255,0.2) !important;">
              <small style="text-transform: uppercase; letter-spacing: 2px; font-weight: 600; opacity: 0.8;">Tréboles Disponibles</small>
              <div class="d-flex align-items-center justify-content-center">
                <h2 class="display-3 mb-0" style="font-weight: 800;"><%= member.rewardPoints %></h2>
                <i class="fas fa-clover ml-2" style="font-size: 2rem; color: #fff;"></i>
              </div>
            </div>
            <div class="col-md-4">
              <small style="text-transform: uppercase; letter-spacing: 2px; font-weight: 600; opacity: 0.8;">Categoría</small>
              <h2 class="mb-0" style="font-weight: 700; text-transform: uppercase;">
                <%= member.tier %>
              </h2>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row mt-4">
    <% 
      // Definimos las nuevas acciones comerciales de Club MAPFRE
      const accionesClub = [
        { 
          id: 'eci', 
          title: 'Compra en El Corte Inglés', 
          description: 'Obtén tréboles por tus compras en moda, tecnología y hogar en centros asociados.', 
          points: 15, 
          image: '/img/compra1.png', 
          journalType: 'Accrual', 
          journalSubType: 'Compra en El Corte Inglés' 
        },
        { 
          id: 'amazon', 
          title: 'Compra en Amazon', 
          description: 'Tus compras online ahora te ayudan a reducir el coste de tu próxima póliza.', 
          points: 10, 
          image: '/img/compra4.png', 
          journalType: 'Accrual', 
          journalSubType: 'Compra en Amazon' 
        },
        { 
          id: 'repsol', 
          title: 'Repostaje en Repsol', 
          description: 'Suma tréboles en cada repostaje de carburante en la red de estaciones Repsol.', 
          points: 25, 
          image: '/img/compra5.png', 
          journalType: 'Accrual', 
          journalSubType: 'Repostaje en Repsol' 
        },
        { 
          id: 'tarjeta_mapfre', 
          title: 'Pago con Tarjeta MAPFRE', 
          description: 'Bonificación exclusiva por utilizar tu tarjeta de crédito MAPFRE en cualquier establecimiento.', 
          points: 50, 
          image: '/img/compra2.png', 
          journalType: 'Accrual', 
          journalSubType: 'Pago con Tarjeta Mapfre' 
        }
      ];
    %>

    <% accionesClub.forEach(option => { %>
      <div class="col-md-3 mb-4"> <div class="card h-100 shadow-sm border-0" style="border-radius: 20px; overflow: hidden; transition: all 0.3s ease;">
          <div style="height: 160px; overflow: hidden; position: relative;">
             <img src="<%= option.image %>" class="card-img-top" alt="<%= option.title %>" 
                  onerror="this.src='https://images.unsplash.com/photo-1556742049-13e7323fbb5a?w=400'"
                  style="width: 100%; height: 100%; object-fit: cover;">
          </div>

          <div class="card-body d-flex flex-column text-center p-3">
            <h5 class="card-title font-weight-bold" style="color: #333; font-size: 1.1rem; min-height: 2.5rem;"><%= option.title %></h5>
            <p class="card-text text-muted mb-3" style="font-size: 0.85rem; line-height: 1.4;"><%= option.description %></p>
            
            <div class="mt-auto">
              <h4 style="color: #d81e05; font-weight: 800; margin-bottom: 15px;">+<%= option.points %> <small>Tréboles</small></h4>
              
              <form action="/transaction" method="POST">
                <input type="hidden" name="type" value="Accrual">
                <input type="hidden" name="points" value="<%= option.points %>">
                <input type="hidden" name="journalType" value="<%= option.journalType %>">
                <input type="hidden" name="journalSubType" value="<%= option.journalSubType %>">
                
                <button type="submit" class="btn btn-danger btn-block shadow-sm" style="background: #d81e05; border: none; color: #fff; border-radius: 50px; padding: 10px; font-weight: 700; font-size: 0.8rem; letter-spacing: 1px; text-transform: uppercase;">
                   Registrar Compra
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    <% }); %>
  </div>

  <div class="text-center mt-5 mb-5">
    <a href="/" class="btn btn-outline-secondary" style="border-radius: 50px; padding: 10px 30px;">
      <i class="fas fa-chevron-left mr-2"></i> Volver al Inicio
    </a>
  </div>
</div>

<%- include('partials/footer') %>