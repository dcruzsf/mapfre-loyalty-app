<%- include('partials/header', {currentPage: 'accrual'}) %>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/"><%= t('navigation.home') %></a></li>
    <li class="breadcrumb-item active"><%= t('pages.accrual.breadcrumb') %></li>
  </ol>
</nav>

<div class="page-header-space text-center">
  <h1 class="page-title"><%= t('pages.accrual.title') %></h1>
  <p class="text-muted"><%= t('pages.accrual.description') %></p>
</div>

<% if (typeof message !== 'undefined' && message) { %>
    <div class="notification show">
      <div class="notification-title"><%= t('pages.accrual.notification.success') %></div>
      <div class="notification-body"><%= message %></div>
      <% if (typeof pointsEarned !== 'undefined' && pointsEarned) { %>
          <div class="notification-points">+<%= pointsEarned %> <%= t('pages.accrual.notification.pointsEarned') %></div>
      <% } %>
    </div>
<% } %>

<div class="member-summary">
  <div class="member-stat">
    <div class="member-stat-label"><%= t('member.levelPoints') %></div>
    <div class="member-stat-value"><%= member.levelPoints %></div>
  </div>

  <div class="member-stat">
    <div class="member-stat-label"><%= t('member.rewardPoints') %></div>
    <div class="member-stat-value"><%= member.rewardPoints %></div>
  </div>

  <div class="member-stat">
    <div class="member-stat-label"><%= t('member.tier') %></div>
    <div class="member-stat-value tier-<%= member.tier.toLowerCase() %>">
        <%= t('tiers.' + (member.tier ? member.tier.toLowerCase() : 'bronze')) %>
    </div>
  </div>
</div>

<%- include('partials/tier-progress', {member: member, locale: locale}) %>

<div class="tabs">
  <button class="tab active" data-target="purchases-content"><%= t('pages.accrual.tabs.purchases') %></button>
</div>

<div id="purchases-content" class="tab-content" style="display: block;">
  <div class="row mt-4">
    <% products.forEach(product => { %>
      <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm border-0 animate-in">
          <% 
            // CORRECCIÓN AQUÍ: Forzamos el ID a String para evitar el error de toLowerCase
            const productIdSafe = String(product.id).toLowerCase();
            const imagePath = `/img/${productIdSafe}.jpg`; 
          %>
          <div style="height: 180px; background-image: url('<%= imagePath %>'); background-size: cover; background-position: center; border-radius: 8px 8px 0 0; background-color: #f4f4f4;">
            <div class="d-flex align-items-center justify-content-center h-100" style="color: #ccc; font-size: 10px; text-align: center;">
              <% /* Si no carga la imagen, al menos se verá el nombre del producto */ %>
            </div>
          </div>
          
          <div class="card-body d-flex flex-column">
            <h5 class="card-title" style="color: #d81e05; font-weight: bold;">
                <%= product.name %>
            </h5>
            <p class="card-text" style="font-size: 0.9rem; color: #666; flex-grow: 1;">
                <%= product.description %>
            </p>
            <div class="mt-3 text-center">
                <p class="mb-2" style="font-weight: bold; font-size: 1.1rem; color: #d81e05;">
                    +<%= product.points %> <%= t('pages.accrual.product.points') %>
                </p>
                <form method="POST" action="/accrual/purchase/<%= product.id %>">
                  <button type="submit" class="btn btn-danger btn-block" style="background-color: #d81e05; border: none; font-weight: 500;">
                    <%= t('pages.accrual.product.buy') %>
                  </button>
                </form>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<%- include('partials/footer') %>