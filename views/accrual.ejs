<%- include('partials/header', {currentPage: 'accrual'}) %>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/"><%= t('navigation.home') %></a></li>
    <li class="breadcrumb-item active"><%= t('pages.accrual.breadcrumb') %></li>
  </ol>
</nav>

<div class="page-header-space">
  <h1 class="page-title"><%= t('pages.accrual.title') %></h1>
</div>

<% if (typeof message !== 'undefined') { %>
  <% if (message) { %>
    <div class="notification show">
      <div class="notification-title"><%= t('pages.accrual.notification.success') %></div>
      <div class="notification-body"><%= message %></div>
      <% if (typeof pointsEarned !== 'undefined') { %>
        <% if (pointsEarned) { %>
          <div class="notification-points">+<%= pointsEarned %> <%= t('pages.accrual.notification.pointsEarned') %></div>
        <% } %>
      <% } %>
    </div>
  <% } %>
<% } %>

<!-- Resumen del miembro -->
<div class="member-summary">
  <div class="member-stat">
    <div class="member-stat-label"><%= t('member.levelPoints') %></div>
    <div class="member-stat-value"><%= member.levelPoints %></div>
  </div>

  <div class="member-stat">
    <div class="member-stat-label"><%= t('member.rewardPoints') %></div>
    <div class="member-stat-value"><%= member.rewardPoints %></div>
  </div>

  <div class="member-stat">
    <div class="member-stat-label"><%= t('member.tier') %></div>
    <div class="member-stat-value tier-<%= member.tier.toLowerCase() %>"><%= t('tiers.' + member.tier.toLowerCase()) %></div>
  </div>
</div>

<%- include('partials/tier-progress', {member: member, locale: locale}) %>

<!-- Pestañas (solo operaciones) -->
<div class="tabs">
  <button class="tab active" data-target="purchases-content"><%= t('pages.accrual.tabs.purchases') %></button>
</div>

<!-- Contenido de pestañas -->
<div id="purchases-content" class="tab-content" style="display: block;">
  <div class="product-grid">
    <% products.forEach(product => { %>
      <div class="product-card animate-in">
        <%
          // Determinar si es URL externa o local
          const imageUrl = product.image.startsWith('http') ? product.image : '/img/' + product.image;
        %>
        <div class="product-image" style="background-image: url('<%= imageUrl %>')">
          <% if (!product.image.includes('.jpg') && !product.image.includes('.png') && !product.image.startsWith('http')) { %>
            <span>Imagen: <%= product.name %></span>
          <% } %>
        </div>
        <div class="product-details">
          <h3 class="product-title"><%= product.name %></h3>
          <p class="product-points" style="font-size: 16px; font-weight: bold; color: var(--primary-color);"><%= product.pointsDisplay %></p>
          <p class="product-description" style="font-size: 12px; color: #666;"><%= product.description %></p>
          <form method="POST" action="/accrual/purchase/<%= product.id %>" class="purchase-form">
            <button type="submit" class="btn">
              <%= t('pages.accrual.product.buy') %>
            </button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
</div>


<%- include('partials/footer') %>