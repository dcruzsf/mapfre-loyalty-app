<%- include('partials/header', {currentPage: 'redemption'}) %>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/"><%= t('navigation.home') %></a></li>
    <li class="breadcrumb-item active"><%= t('pages.redemption.breadcrumb') %></li>
  </ol>
</nav>

<div class="page-header-space text-center">
  <h1 class="page-title"><%= t('pages.redemption.title') %></h1>
  <p class="text-muted"><%= t('pages.redemption.description') %></p>
</div>

<% if (typeof message !== 'undefined' && message) { %>
    <div class="notification show">
      <div class="notification-title"><%= t('pages.redemption.notification.success') %></div>
      <div class="notification-body"><%= message %></div>
      <% if (typeof pointsRedeemed !== 'undefined' && pointsRedeemed) { %>
          <div class="notification-points">-<%= pointsRedeemed %> <%= t('pages.redemption.reward.points') %></div>
      <% } %>
    </div>
<% } %>

<div class="member-summary text-center mb-5">
  <div class="member-stat" style="margin: 0 auto; border: 2px solid var(--primary-color); border-radius: 15px; padding: 20px;">
    <div class="member-stat-label" style="color: var(--primary-color); font-weight: bold;">
        <%= (t('member.rewardPoints') + ' ' + t('common.available')).toUpperCase() %>
    </div>
    <div class="member-stat-value" style="font-size: 42px; color: #d81e05;"><%= member.rewardPoints %></div>
  </div>
</div>

<% 
  const renderRewardGrid = (filterArray, title) => { 
    if (filterArray.length > 0) { 
%>
  <h3 class="mt-5 mb-4 border-bottom pb-2" style="color: #333;"><%= title %></h3>
  <div class="row">
    <% filterArray.forEach((reward) => { %>
      <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm border-0 animate-in <%= member.rewardPoints < reward.points ? 'opacity-75' : '' %>">
          <div style="height: 160px; background-image: url('/img/<%= reward.image %>'); background-size: cover; background-position: center; border-radius: 8px 8px 0 0;">
            <% if (member.rewardPoints < reward.points) { %>
              <div style="background: rgba(0,0,0,0.5); height: 100%; display: flex; align-items: center; justify-content: center; border-radius: 8px 8px 0 0;">
                <span class="badge badge-dark">Necesitas más Tréboles</span>
              </div>
            <% } %>
          </div>
          <div class="card-body d-flex flex-column text-center">
            <h5 class="card-title" style="font-weight: bold;"><%= reward.name %></h5>
            <p class="card-text text-muted" style="font-size: 0.9rem; flex-grow: 1;"><%= reward.description %></p>
            <div class="mt-3">
              <p class="mb-3" style="font-weight: bold; font-size: 1.2rem; color: #d81e05;">
                <%= reward.points %> <%= t('pages.redemption.reward.points') %>
              </p>
              <form method="POST" action="/redemption/redeem/<%= reward.id %>">
                <button
                  type="submit"
                  class="btn btn-block <%= member.rewardPoints < reward.points ? 'btn-secondary' : 'btn-danger' %>"
                  style="<%= member.rewardPoints < reward.points ? '' : 'background-color: #d81e05; border: none;' %>"
                  <%= member.rewardPoints < reward.points ? 'disabled' : '' %>
                >
                  <%= member.rewardPoints < reward.points ? t('pages.redemption.reward.insufficientPoints') : t('pages.redemption.reward.redeem') %>
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% 
    } 
  } 
%>

<% renderRewardGrid(rewards.filter(r => r.type === 'redemption'), locale === 'es' ? 'Descuentos en Recibos' : 'Policy Discounts') %>
<% renderRewardGrid(rewards.filter(r => r.type === 'cashback'), locale === 'es' ? 'Tréboles por Dinero' : 'Cashback') %>
<% renderRewardGrid(rewards.filter(r => ['service', 'experience'].includes(r.type)), locale === 'es' ? 'Experiencias y Servicios' : 'Experiences & Services') %>

<% if (codeGenerated) { %>
  <div class="reward-code-container mt-5 mb-4 text-center animate-in celebrate">
    <div class="card border-success" style="background-color: #f0fff4;">
      <div class="card-body">
        <h4 class="text-success">¡Canje realizado con éxito! 🍀</h4>
        <p>Tu solicitud ha sido enviada a Salesforce Loyalty Management.</p>
        <p><strong>Código de confirmación:</strong></p>
        <div class="reward-code" style="background: white; padding: 15px; border-radius: 8px; display: inline-block; border: 2px dashed #28a745;">
          <code style="font-size: 24px; color: #28a745; font-weight: bold;"><%= codeGenerated %></code>
        </div>
      </div>
    </div>
  </div>
<% } %>

<%- include('partials/footer') %>