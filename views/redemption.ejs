<%- include('partials/header', {currentPage: 'redemption'}) %>

<div class="container mt-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb" style="background: transparent; padding-left: 0;">
      <li class="breadcrumb-item"><a href="/" style="color: #d81e05;"><%= t('navigation.home') %></a></li>
      <li class="breadcrumb-item active"><%= t('pages.redemption.breadcrumb') %></li>
    </ol>
  </nav>

  <div class="page-header-space text-center mb-5">
    <h1 class="page-title" style="color: #d81e05; font-weight: 800; text-transform: uppercase;">Canjear mis Tréboles</h1>
    <p class="lead text-muted">Utiliza tus tréboles acumulados para ahorrar en tus seguros o conseguir servicios exclusivos</p>
  </div>

  <% if (typeof message !== 'undefined' && message) { %>
      <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert" style="border-radius: 15px; border-left: 5px solid #28a745;">
        <div class="d-flex align-items-center">
          <i class="fas fa-check-circle mr-3" style="font-size: 1.5rem;"></i>
          <div>
            <strong><%= t('pages.redemption.notification.success') %></strong><br>
            <%= message %>
          </div>
        </div>
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
  <% } %>

  <div class="row justify-content-center mb-5">
    <div class="col-md-6">
      <div class="card shadow border-0 text-center" style="border-radius: 20px; background: #333; color: white;">
        <div class="card-body p-4">
          <small style="text-transform: uppercase; letter-spacing: 2px; opacity: 0.8;">Tus Tréboles Disponibles</small>
          <div class="d-flex align-items-center justify-content-center mt-2">
            <h2 class="display-4 mb-0" style="font-weight: 800;"><%= member.rewardPoints %></h2>
            <i class="fas fa-clover ml-3" style="font-size: 2.5rem; color: #fff;"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <% 
    // Definimos la función dentro del contexto para que sea segura
    const renderRewardGrid = (filterArray, title) => { 
      if (filterArray && filterArray.length > 0) { 
  %>
    <h3 class="mt-5 mb-4 border-bottom pb-2" style="color: #333; font-weight: 700;"><%= title %></h3>
    <div class="row">
      <% filterArray.forEach((reward) => { %>
        <div class="col-md-4 mb-4">
          <div class="card h-100 shadow-sm border-0" style="border-radius: 20px; overflow: hidden;">
            <div style="height: 160px; position: relative; overflow: hidden;">
              <img src="/img/<%= reward.image %>" 
                   onerror="this.src='https://images.unsplash.com/photo-1563013544-824ae1b704d3?w=400'"
                   style="width: 100%; height: 100%; object-fit: cover;">
              <% if (member.rewardPoints < reward.points) { %>
                <div style="position: absolute; top: 0; left: 0; background: rgba(0,0,0,0.6); width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
                  <span class="badge badge-warning p-2">Faltan <%= reward.points - member.rewardPoints %> tréboles</span>
                </div>
              <% } %>
            </div>
            <div class="card-body d-flex flex-column text-center">
              <h5 class="card-title" style="font-weight: 700; min-height: 3rem;"><%= reward.name %></h5>
              <p class="card-text text-muted small" style="flex-grow: 1;"><%= reward.description %></p>
              <div class="mt-3">
                <h4 style="color: #d81e05; font-weight: 800; margin-bottom: 15px;">
                  <%= reward.points %> <small>Tréboles</small>
                </h4>
                <form method="POST" action="/redemption/redeem/<%= reward.id %>">
                  <button
                    type="submit"
                    class="btn btn-block btn-danger"
                    style="border-radius: 50px; font-weight: 700; text-transform: uppercase; font-size: 0.8rem; background: #d81e05; border: none;"
                    <%= member.rewardPoints < reward.points ? 'disabled' : '' %>
                  >
                    <%= member.rewardPoints < reward.points ? 'Saldo Insuficiente' : 'Canjear ahora' %>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% 
      } 
    } 
  %>

  <% if (typeof rewards !== 'undefined' && rewards && rewards.length > 0) { %>
      <% renderRewardGrid(rewards.filter(r => r.type === 'redemption'), 'Descuentos en Recibos') %>
      <% renderRewardGrid(rewards.filter(r => r.type === 'cashback'), 'Tréboles por Dinero') %>
      <% renderRewardGrid(rewards.filter(r => ['service', 'experience'].includes(r.type)), 'Experiencias y Servicios') %>
  <% } else { %>
      <div class="text-center p-5">
        <i class="fas fa-search mb-3" style="font-size: 3rem; color: #ccc;"></i>
        <p class="text-muted">No hemos encontrado recompensas disponibles para tu nivel actual.</p>
      </div>
  <% } %>

  <% if (codeGenerated) { %>
    <div class="reward-code-container mt-5 mb-5 text-center shadow-lg" style="border-radius: 20px; border: none; background: #f0fff4; padding: 30px;">
        <h4 class="text-success" style="font-weight: 800;">¡CANJE CONFIRMADO! 🍀</h4>
        <p>Tu solicitud ha sido procesada por Salesforce Loyalty Management.</p>
        <div class="my-4">
          <span class="text-muted small d-block mb-2">CÓDIGO DE CANJE</span>
          <div style="background: white; padding: 20px; border-radius: 10px; display: inline-block; border: 2px dashed #28a745;">
            <code style="font-size: 28px; color: #28a745; font-weight: bold; letter-spacing: 2px;"><%= codeGenerated %></code>
          </div>
        </div>
        <a href="/" class="btn btn-outline-success">Volver al inicio</a>
    </div>
  <% } %>

</div>

<%- include('partials/footer') %>