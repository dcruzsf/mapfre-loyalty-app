<%- include('partials/header', {currentPage: 'achievements'}) %>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/"><%= t('navigation.home') %></a></li>
    <li class="breadcrumb-item active"><%= t('pages.achievements.breadcrumb') %></li>
  </ol>
</nav>

<div class="page-header-space">
  <h1 class="page-title"><%= t('pages.achievements.title') %></h1>
</div>

<!-- Resumen de progreso -->
<div class="member-summary">
  <div class="member-stat">
    <div class="member-stat-label"><%= t('member.name') %></div>
    <div class="member-stat-value"><%= member.name %></div>
  </div>

  <div class="member-stat">
    <div class="member-stat-label"><%= t('member.levelPoints') %></div>
    <div class="member-stat-value"><%= member.levelPoints %></div>
  </div>

  <div class="member-stat">
    <div class="member-stat-label"><%= t('member.rewardPoints') %></div>
    <div class="member-stat-value"><%= member.rewardPoints %></div>
  </div>

  <div class="member-stat">
    <div class="member-stat-label"><%= t('member.tier') %></div>
    <div class="member-stat-value tier-<%= member.tier.toLowerCase() %>"><%= t('tiers.' + member.tier.toLowerCase()) %></div>
  </div>
</div>

<!-- Contador de logros y barra de progreso -->
<div class="achievements-progress text-center mt-4 mb-4">
  <h3 class="mb-3"><%= t('pages.achievements.status.earned') %>: <%= member.achievements.length %> / 10</h3>
  <div class="tier-progress-container" style="max-width: 600px; margin: 0 auto;">
    <% const achievementProgress = (member.achievements.length / 10) * 100; %>
    <div class="tier-progress-bar">
      <div class="tier-progress-fill" data-width="<%= achievementProgress %>"></div>
    </div>
    <div class="tier-progress-text">
      <%= Math.round(achievementProgress) %>% <%= locale === 'es' ? 'completado' : 'completed' %>
    </div>
  </div>
</div>

<!-- Pestañas de categorías -->
<div class="tabs">
  <button class="tab active" data-target="all-achievements"><%= t('pages.achievements.categories.all') %></button>
  <button class="tab" data-target="purchase-achievements"><%= locale === 'es' ? 'Compras' : 'Purchases' %></button>
  <button class="tab" data-target="social-achievements">Social</button>
  <button class="tab" data-target="tier-achievements"><%= locale === 'es' ? 'Niveles' : 'Tiers' %></button>
</div>

<!-- Logros -->
<div id="all-achievements" class="tab-content" style="display: block;">
  <div class="achievements-grid">
    <% allAchievements.forEach(achievement => { %>
      <% const unlocked = member.hasAchievement(achievement.id); %>
      <div class="achievement-card <%= unlocked ? 'unlocked' : 'locked' %> animate-in">
        <div class="achievement-icon <%= unlocked ? '' : 'achievement-locked-icon' %>">
          <% if (unlocked) { %>
            <i class="fas fa-<%= achievement.icon || 'star' %>"></i>
          <% } else { %>
            ?
          <% } %>
        </div>
        <h3 class="achievement-title">
          <% if (unlocked) { %>
            <%= achievement.name %>
          <% } else { %>
            <% if (achievement.hideWhenLocked) { %>
              ???
            <% } else { %>
              <%= achievement.name %>
            <% } %>
          <% } %>
        </h3>
        <% if (unlocked) { %>
          <p class="achievement-points"><%= achievement.points %> <%= t('units.points') %></p>
          <p class="achievement-date" style="color: var(--secondary-color); font-weight: 500;">
            <%= t('pages.achievements.status.earned') %>
          </p>
        <% } else { %>
          <p class="achievement-points">
            <% if (achievement.hideWhenLocked) { %>
              ???
            <% } else { %>
              <%= achievement.points %> <%= t('units.points') %>
            <% } %>
          </p>
          <p class="achievement-description">
            <% if (achievement.id === 'challenge_profile_complete') { %>
              <%= achievement.hint || (locale === 'es' ? 'Completa toda la información de tu perfil (4 veces)' : 'Complete all your profile information (4 times)') %>
            <% } else { %>
              <%= achievement.hint || (locale === 'es' ? 'Sigue participando para desbloquear' : 'Keep participating to unlock') %>
            <% } %>
          </p>
        <% } %>
      </div>
    <% }); %>
  </div>
</div>

