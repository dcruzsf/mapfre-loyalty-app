<% if (typeof newAchievement !== 'undefined') { %>
  <% if (newAchievement) { %>
    <div class="notification show">
      <div class="notification-title"><%= locale === 'es' ? '¡LOGRO DESBLOQUEADO!' : 'ACHIEVEMENT UNLOCKED!' %></div>
      <div class="notification-body"><%= achievementName %></div>
      <% if (typeof achievementPoints !== 'undefined') { %>
        <% if (achievementPoints > 0) { %>
          <div class="notification-points">+<%= achievementPoints %> <%= t('units.points') %></div>
        <% } %>
      <% } %>
    </div>
  <% } %>
<% } %>

<%- include('partials/footer') %>