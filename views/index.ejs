<%- include('partials/header', {currentPage: 'home'}) %>

<div class="row page-header-space text-center">
  <div class="col-md-12">
    <h1 class="page-title"><%= brand.fullName %></h1>
    <p class="page-subtitle"><%= brand.messages.tagline %></p>
  </div>
</div>

<% if (member) { %>
  <div class="row">
    <div class="col-md-12">
      <div class="card">
        <div class="card-body">
          <h3><%= t('member.name') %>: <%= member.name %></h3>
          <p><strong><%= t('member.email') %>:</strong> <%= member.email %></p>

          <div class="member-summary">
            <div class="member-stat">
              <div class="member-stat-label"><%= t('member.levelPoints') %></div>
              <div class="member-stat-value"><%= member.levelPoints %></div>
            </div>

            <div class="member-stat">
              <div class="member-stat-label"><%= t('member.rewardPoints') %></div>
              <div class="member-stat-value"><%= member.rewardPoints %></div>
            </div>

            <div class="member-stat">
              <div class="member-stat-label"><%= t('member.tier') %></div>
              <div class="member-stat-value tier-<%= member.tier.toLowerCase() %>"><%= t('tiers.' + member.tier.toLowerCase()) %></div>
            </div>
          </div>

          <!-- Barra de progreso de Tiers -->
          <%
            // Definir rangos de tiers
            const tierRanges = {
              'Bronze': { min: 0, max: 499, next: 'Plata' },
              'Silver': { min: 500, max: 999, next: 'Oro' },
              'Gold': { min: 1000, max: 1999, next: 'Platino' },
              'Platinum': { min: 2000, max: null, next: null }
            };

            // Normalizar el tier del miembro
            const currentTierKey = member.tier;
            const tierRange = tierRanges[currentTierKey] || tierRanges['Bronze'];

            // Calcular progreso
            let progressPercent = 0;
            let pointsNeeded = 0;
            let nextTierName = tierRange.next;

            if (tierRange.max !== null) {
              const pointsInRange = member.levelPoints - tierRange.min;
              const rangeSize = tierRange.max - tierRange.min + 1;
              progressPercent = Math.min(Math.max((pointsInRange / rangeSize) * 100, 0), 100);
              pointsNeeded = tierRange.max + 1 - member.levelPoints;
            } else {
              progressPercent = 100; // Tier máximo alcanzado
            }
          %>

          <% if (nextTierName) { %>
            <div class="tier-progress-section mt-4">
              <h5 class="mb-3" style="text-align: center;"><%= locale === 'es' ? 'Progreso al siguiente nivel' : 'Progress to next tier' %></h5>
              <div class="tier-progress-container">
                <div class="tier-progress-bar">
                  <div class="tier-progress-fill" data-width="<%= progressPercent %>"></div>
                </div>
                <div class="tier-progress-text">
                  <%= member.levelPoints %>/<%= tierRange.max + 1 %> <%= t('member.pointsToNext') %> <%= nextTierName %>
                  <% if (pointsNeeded > 0) { %>
                    (<%= pointsNeeded %> <%= locale === 'es' ? 'puntos restantes' : 'points remaining' %>)
                  <% } %>
                </div>
              </div>
            </div>
          <% } else { %>
            <div class="tier-progress-section mt-4" style="text-align: center;">
              <h5 class="mb-3">🏆 <%= locale === 'es' ? '¡Nivel máximo alcanzado!' : 'Maximum tier reached!' %></h5>
            </div>
          <% } %>

          <script>
            document.addEventListener('DOMContentLoaded', function() {
              const progressBars = document.querySelectorAll('.tier-progress-fill[data-width]');
              progressBars.forEach(bar => {
                const width = bar.getAttribute('data-width');
                if (width) {
                  bar.style.width = width + '%';
                }
              });
            });
          </script>
          
          <!-- Sección de acciones destacada -->
          <div class="action-section">
            <h4><%= t('home.whatToDo') %></h4>
            <div class="row">
              <div class="col-md-6 mb-3">
                <a href="/accrual" class="btn action-btn">
                  <i class="fas fa-coins"></i> <%= t('navigation.earnPoints') %>
                </a>
              </div>
              <div class="col-md-6 mb-3">
                <a href="/redemption" class="btn action-btn">
                  <i class="fas fa-gift"></i> <%= t('navigation.redeemPoints') %>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% } else { %>
  <div class="row mt-4">
    <div class="col-md-8 offset-md-2">
      <div class="card">
        <div class="card-body text-center">
          <h2 class="mb-4"><%= brand.messages.welcome %></h2>
          <p class="lead mb-4"><%= t('home.joinDescription') %></p>
          <a href="/register" class="btn btn-primary btn-lg mb-3"><%= t('navigation.register') %></a>
          <div class="row mt-4">
            <% brand.messages.features.forEach(feature => { %>
              <div class="col-md-4 text-center">
                <div class="card-body">
                  <i class="fas fa-<%= feature.title === 'Gana recompensas' ? 'gift' : feature.title === 'Consigue logros' ? 'trophy' : 'level-up-alt' %> fa-3x mb-3"></i>
                  <h4><%= feature.title %></h4>
                  <p><%= feature.description %></p>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% } %>

<%- include('partials/footer') %>