<%- include('partials/header', {currentPage: 'home'}) %>

<div class="row page-header-space text-center">
  <div class="col-md-12">
    <h1 class="page-title" style="color: #d81e05;"><%= brand.fullName %></h1>
    <p class="page-subtitle"><%= brand.messages.tagline %></p>
  </div>
</div>

<% if (member) { %>
  <div class="row">
    <div class="col-md-8 offset-md-2"> 
      
      <div class="text-center mb-4">
        <h2 style="font-weight: 800; font-size: 28px;">Hola, <%= member.name.split(' ')[0] %> 👋</h2>
        <p style="color: #707070;"><%= member.email %></p>
      </div>

      <div class="member-summary" style="background: #191919; border-radius: 30px; padding: 50px 20px; text-align: center; display: block;">
        <div class="member-stat" style="margin: 0 auto;">
          <div class="member-stat-label" style="color: #FFFFFF; letter-spacing: 2px; font-size: 14px; font-weight: 700; margin-bottom: 15px; opacity: 0.8;">
            MIS TRÉBOLES
          </div>
          <div class="member-stat-value" style="font-size: 80px; line-height: 1; font-weight: 800; color: #d81e05;">
            <%= member.rewardPoints %>
          </div>
        </div>
      </div>

      <div class="action-section" style="background: transparent; box-shadow: none; padding: 0; margin-top: 30px;">
        <div class="row">
          <div class="col-md-6 mb-3">
            <a href="/accrual" class="btn" style="background: #d81e05; border: none; color: white; font-weight: 700; border-radius: 50px; padding: 15px;">
              <i class="fas fa-plus-circle"></i> GANAR TRÉBOLES
            </a>
          </div>
          <div class="col-md-6 mb-3">
            <a href="/redemption" class="btn btn-secondary" style="border-radius: 50px; padding: 15px; font-weight: 700;"> 
              <i class="fas fa-gift"></i> CANJEAR
            </a>
          </div>
        </div>
      </div>

      <% if (typeof transactions !== 'undefined' && transactions && transactions.length > 0) { %>
        <div class="card border-0 shadow-sm mt-4 mb-5" style="border-radius: 20px; overflow: hidden;">
          <div class="card-header bg-white p-4 border-0">
            <h4 style="font-weight: 800; margin: 0; color: #191919;">Últimos Movimientos</h4>
          </div>
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead style="background-color: #f8f9fa;">
                <tr>
                  <th class="pl-4 border-0 text-muted" style="font-size: 11px; text-transform: uppercase;">Fecha</th>
                  <th class="border-0 text-muted" style="font-size: 11px; text-transform: uppercase;">Concepto</th>
                  <th class="border-0 text-muted" style="font-size: 11px; text-transform: uppercase;">Estado</th>
                  <th class="pr-4 text-right border-0 text-muted" style="font-size: 11px; text-transform: uppercase;">Tréboles</th>
                </tr>
              </thead>
              <tbody>
                <% transactions.forEach(function(tx) { %>
                  <tr>
                    <td class="pl-4 py-3"><%= tx.date %></td>
                    <td class="py-3"><strong><%= tx.description %></strong></td>
                    <td class="py-3">
                      <span class="badge <%= tx.status === 'Processed' ? 'badge-success' : 'badge-warning' %>">
                        <%= tx.status === 'Processed' ? 'Procesado' : 'Pendiente' %>
                      </span>
                    </td>
                    <td class="pr-4 text-right py-3" style="font-weight: 800; color: <%= tx.isNegative ? '#ff4444' : '#d81e05' %>;">
                      <%= tx.isNegative ? '-' : '+' %><%= tx.amount %>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>
    </div>
  </div>
<% } else { %>
  <div class="row mt-4 text-center">
    <div class="col-md-8 offset-md-2">
      <h2 class="mb-4" style="font-size: 36px; font-weight: 800;"><%= brand.messages.welcome %></h2>
      <a href="/register" class="btn btn-lg mb-5" style="background: #d81e05; color: white; border-radius: 50px; padding: 15px 40px;">
        <%= t('navigation.register') %>
      </a>
    </div>
  </div>
<% } %>

<%- include('partials/footer') %>