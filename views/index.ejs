<%- include('partials/header', {currentPage: 'home'}) %>

<div class="row page-header-space text-center">
  <div class="col-md-12">
    <h1 class="page-title"><%= brand.fullName %></h1>
    <p class="page-subtitle"><%= brand.messages.tagline %></p>
  </div>
</div>

<% if (member) { %>
  <div class="row">
    <div class="col-md-12">
      <div class="card">
        <div class="card-body">
          <h3><%= t('member.name') %>: <%= member.name %></h3>
          <p><strong><%= t('member.email') %>:</strong> <%= member.email %></p>

          <div class="member-summary">
            <div class="member-stat">
              <div class="member-stat-label">PUNTOS NIVEL</div>
              <div class="member-stat-value"><%= member.levelPoints %></div>
            </div>

            <div class="member-stat">
              <div class="member-stat-label">TRÉBOLES</div>
              <div class="member-stat-value"><%= member.rewardPoints %></div>
            </div>

            <div class="member-stat">
              <div class="member-stat-label">NIVEL ACTUAL</div>
              <div class="member-stat-value tier-<%= member.tier.toLowerCase() %>">
                <%= t('tiers.' + (member.tier ? member.tier.toLowerCase() : 'basic')) %>
              </div>
            </div>
          </div>

          <%- include('partials/tier-progress', {member: member, locale: locale}) %>
          
          <div class="action-section">
            <h4>¿Qué quieres hacer hoy?</h4>
            <div class="row">
              <div class="col-md-6 mb-3">
                <a href="/accrual" class="btn action-btn">
                  <i class="fas fa-coins"></i> Consigue Tréboles
                </a>
              </div>
              <div class="col-md-6 mb-3">
                <a href="/redemption" class="btn action-btn">
                  <i class="fas fa-gift"></i> Canjear Tréboles
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% } else { %>
  <% } %>

<%- include('partials/footer') %>