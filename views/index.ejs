<%- include('partials/header', {currentPage: 'home'}) %>

<div class="container mt-5">
  <div class="row text-center mb-5">
    <div class="col-12">
      <h1 class="display-4" style="color: #D31411; font-weight: 800; text-transform: uppercase;">Club MAPFRE</h1>
      <p class="lead text-muted">Tu confianza siempre tiene recompensa</p>
    </div>
  </div>

  <% if (member) { %>
    <div class="row justify-content-center">
      <div class="col-md-8 text-center">
        <h2 class="mb-4">Hola, <%= member.name.split(' ')[0] %> 👋</h2>
        
        <div class="member-summary" style="background: #191919; border-radius: 30px; padding: 50px 20px; color: white;">
          <div class="member-stat">
            <div style="opacity: 0.8; letter-spacing: 2px; font-weight: 700;">MIS TRÉBOLES</div>
            <div style="font-size: 80px; font-weight: 900; color: #D31411;"><%= member.rewardPoints %></div>
          </div>
        </div>

        <div class="row mt-5">
          <div class="col-md-6 mb-3">
            <a href="/accrual" class="btn btn-danger btn-lg btn-block" style="background: #D31411; border-radius: 50px; font-weight: 700; padding: 15px;">
              GANAR TRÉBOLES
            </a>
          </div>
          <div class="col-md-6 mb-3">
            <a href="/redemption" class="btn btn-dark btn-lg btn-block" style="border-radius: 50px; padding: 15px; font-weight: 700;">
              CANJEAR
            </a>
          </div>
        </div>
      </div>
    </div>
  <% } else { %>
    <div class="text-center py-5">
      <h2 style="font-weight: 800;">¡Bienvenido al Club MAPFRE!</h2>
      <a href="/register" class="btn btn-danger btn-lg mt-4" style="background: #D31411; border-radius: 50px; padding: 15px 40px; font-weight: 700;">
        ÚNETE AL CLUB
      </a>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>