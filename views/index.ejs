<%- include('partials/header', {currentPage: 'home'}) %>

<div class="container mt-5">
  <div class="text-center mb-5">
    <h1 class="display-4 font-weight-bold" style="color: #D31411; letter-spacing: -2px;">CLUB MAPFRE</h1>
    <p class="lead text-muted">Tu confianza siempre tiene recompensa</p>
  </div>

  <% if (member) { %>
    <div class="row justify-content-center">
      <div class="col-md-9 text-center">
        <h2 class="mb-4" style="font-weight: 700;">Hola, <%= member.name.split(' ')[0] %> 👋</h2>
        
        <div class="card shadow-lg border-0" style="border-radius: 40px; background: #121212; color: white; padding: 45px;">
          <div class="card-body">
            <div class="row align-items-center">
              <div class="col-6 border-right border-secondary">
                <small style="text-transform: uppercase; letter-spacing: 2px; font-weight: 700; opacity: 0.6;">MIS TRÉBOLES</small>
                <h2 class="display-2 mb-0" style="font-weight: 900; color: #D31411;"><%= member.rewardPoints %></h2>
              </div>
              <div class="col-6">
                <small style="text-transform: uppercase; letter-spacing: 2px; font-weight: 700; opacity: 0.6;">PUNTOS NIVEL</small>
                <h2 class="display-4 mb-0" style="font-weight: 800;"><%= member.levelPoints %></h2>
                <div class="mt-2">
                    <span class="badge badge-danger px-3 py-2" style="border-radius: 50px; background: #D31411;">Nivel: <%= member.tier %></span>
                </div>
              </div>
            </div>

            <div class="mt-5 px-3">
              <div class="d-flex justify-content-between mb-2">
                <small style="font-weight: 600; opacity: 0.8; text-transform: uppercase;">Hacia nivel <%= nextTier %></small>
                <small style="font-weight: 700;"><%= member.levelPoints %> / <%= nextThreshold %></small>
              </div>
              <div class="progress" style="height: 12px; border-radius: 20px; background: #2a2a2a;">
                <div class="progress-bar progress-bar-striped progress-bar-animated" 
                     role="progressbar" 
                     style="width: <%= progressPercent %>%; background-color: #D31411;" 
                     aria-valuenow="<%= progressPercent %>" aria-valuemin="0" aria-valuemax="100">
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="row mt-5">
          <div class="col-md-6 mb-3">
            <a href="/accrual" class="btn btn-danger btn-lg btn-block shadow-lg py-3" style="background: #D31411; border-radius: 50px; font-weight: 800; border: none;">
              GANAR TRÉBOLES
            </a>
          </div>
          <div class="col-md-6 mb-3">
            <a href="/redemption" class="btn btn-dark btn-lg btn-block shadow-lg py-3" style="background: #222; border-radius: 50px; font-weight: 800; border: none;">
              CANJEAR TRÉBOLES
            </a>
          </div>
        </div>
      </div>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>