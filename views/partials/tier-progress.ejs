<!-- Barra de progreso de Tiers -->
<%
  // Normalizar tier antes de usar
  const tierNormalization = {
    'Basic': 'Bronze',
    'Bronze': 'Bronze',
    'Bronce': 'Bronze',
    'Plus': 'Silver',
    'Silver': 'Silver',
    'Plata': 'Silver',
    'Premium': 'Gold',
    'Gold': 'Gold',
    'Oro': 'Gold',
    'Elite': 'Platinum',
    'Platinum': 'Platinum',
    'Platino': 'Platinum'
  };

  // Definir rangos de tiers
  const tierRanges = {
    'Bronze': { min: 0, max: 499, next: locale === 'es' ? 'Plata' : 'Silver' },
    'Silver': { min: 500, max: 999, next: locale === 'es' ? 'Oro' : 'Gold' },
    'Gold': { min: 1000, max: 1999, next: locale === 'es' ? 'Platino' : 'Platinum' },
    'Platinum': { min: 2000, max: null, next: null }
  };

  // Normalizar el tier del miembro
  const normalizedTier = tierNormalization[member.tier] || 'Bronze';
  const tierRange = tierRanges[normalizedTier];

  // Calcular progreso
  let progressPercent = 0;
  let pointsNeeded = 0;
  let nextTierName = tierRange.next;

  if (tierRange.max !== null) {
    const pointsInRange = member.levelPoints - tierRange.min;
    const rangeSize = tierRange.max - tierRange.min + 1;
    progressPercent = Math.min(Math.max((pointsInRange / rangeSize) * 100, 0), 100);
    pointsNeeded = tierRange.max + 1 - member.levelPoints;
  } else {
    progressPercent = 100; // Tier máximo alcanzado
  }
%>

<% if (nextTierName) { %>
  <div class="tier-progress-section mt-4">
    <h5 class="mb-3" style="text-align: center;"><%= locale === 'es' ? 'Progreso al siguiente nivel' : 'Progress to next tier' %></h5>
    <div class="tier-progress-container">
      <div class="tier-progress-bar">
        <div class="tier-progress-fill" data-width="<%= progressPercent %>"></div>
      </div>
      <div class="tier-progress-text" style="margin-top: 8px;">
        <strong><%= Math.round(progressPercent) %>%</strong> <%= locale === 'es' ? 'completado' : 'complete' %>
        <br>
        <span style="font-size: 14px;">
          <%= member.levelPoints %> <%= locale === 'es' ? 'puntos actuales' : 'current points' %>
          <% if (pointsNeeded > 0) { %>
            | <%= pointsNeeded %> <%= locale === 'es' ? 'para' : 'to' %> <%= nextTierName %>
          <% } %>
        </span>
      </div>
    </div>
  </div>
<% } else { %>
  <div class="tier-progress-section mt-4" style="text-align: center;">
    <h5 class="mb-3">🏆 <%= locale === 'es' ? '¡Nivel máximo alcanzado!' : 'Maximum tier reached!' %></h5>
  </div>
<% } %>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const progressBars = document.querySelectorAll('.tier-progress-fill[data-width]');
    progressBars.forEach(bar => {
      const width = bar.getAttribute('data-width');
      if (width) {
        bar.style.width = width + '%';
      }
    });
  });
</script>
