<%- include('partials/header', {currentPage: 'register'}) %>

<div class="row mt-5">
  <div class="col-md-8 offset-md-2">
    <div class="card">
      <div class="card-header">
        <h2 class="mb-0"><%= t('pages.register.title') %> en <%= brand.fullName %></h2>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-4 d-none d-md-block">
            <div class="text-center mb-4">
              <img src="https://upload.wikimedia.org/wikipedia/commons/f/fd/LOGO-MAPFRE.jpg" alt="Mapfre" style="max-width: 100%; height: auto; border-radius: 4px;">
            </div>
            
            <div class="benefits-list">
              <h5><%= brand.messages.benefits.title %></h5>
              <ul class="list-unstyled">
                <% brand.messages.benefits.list.forEach(benefit => { %>
                  <li class="mb-2"><i class="fas fa-check mr-2"></i> <%= benefit %></li>
                <% }); %>
              </ul>
            </div>
          </div>
          
          <div class="col-md-8">
            <% if (typeof message !== 'undefined' && message) { %>
              <div class="alert alert-info">
                <%= message %>
              </div>
            <% } %>
            
            <% if (typeof error !== 'undefined' && error) { %>
              <div class="alert alert-danger">
                <%= error %>
              </div>
            <% } %>
            
            <form method="POST" action="/register">
              <div class="form-group">
                <label for="name" class="form-label"><%= t('pages.register.form.name').toUpperCase() %></label>
                <input
                  type="text"
                  class="form-control"
                  id="name"
                  name="name"
                  required
                  placeholder="<%= locale === 'es' ? 'Ej: Juan Pérez' : 'Ex: John Doe' %>"
                  value="<%= typeof formData !== 'undefined' ? formData.name : '' %>"
                >
              </div>

              <div class="form-group">
                <label for="email" class="form-label"><%= t('pages.register.form.email').toUpperCase() %></label>
                <input
                  type="email"
                  class="form-control"
                  id="email"
                  name="email"
                  required
                  placeholder="<%= locale === 'es' ? 'Ej: juan.perez@email.com' : 'Ex: john.doe@email.com' %>"
                  value="<%= typeof formData !== 'undefined' ? formData.email : '' %>"
                >
                <small class="form-text text-muted">
                  <%= locale === 'es' ? 'Cada email solo puede registrarse una vez.' : 'Each email can only be registered once.' %>
                </small>
              </div>
              
              <div class="form-group">
                <label class="form-label"><%= t('pages.register.form.interests').toUpperCase() %></label>
                <% brand.categories.forEach(category => { %>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="preferences" value="<%= category.id %>" id="<%= category.id %>">
                    <label class="form-check-label" for="<%= category.id %>">
                      <%= category.label %>
                    </label>
                  </div>
                <% }); %>
              </div>
              
              <button type="submit" class="btn btn-primary btn-lg btn-block mt-4"><%= t('pages.register.form.submit') %></button>
            </form>

            <div class="text-center mt-3">
              <button type="button" id="autofillBtn" class="btn btn-secondary btn-sm" style="font-size: 13px; padding: 8px 16px;">
                <i class="fas fa-magic"></i> Rellenar automáticamente (Demo)
              </button>
            </div>

            <div class="text-center mt-4">
              <div class="alert alert-info" style="border-left: 4px solid var(--accent-color); background-color: #f8f9fa; border: 1px solid #dee2e6;">
                <i class="fas fa-info-circle"></i>
                <strong>Demo Mapfre</strong>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>