<%- include('partials/header', {currentPage: 'register'}) %>

<div class="row mt-5">
  <div class="col-md-8 offset-md-2">
    <div class="card">
      <div class="card-header">
        <h2 class="mb-0"><%= t('pages.register.title') %> en <%= brand.fullName %></h2>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-4 d-none d-md-block">
            <div class="text-center mb-4">
              <img src="https://upload.wikimedia.org/wikipedia/commons/f/fd/LOGO-MAPFRE.jpg" alt="Mapfre" style="max-width: 100%; height: auto; border-radius: 4px;">
            </div>
            
            <div class="benefits-list">
              <h5><%= brand.messages.benefits.title %></h5>
              <ul class="list-unstyled">
                <% brand.messages.benefits.list.forEach(benefit => { %>
                  <li class="mb-2"><i class="fas fa-check mr-2"></i> <%= benefit %></li>
                <% }); %>
              </ul>
            </div>
          </div>
          
          <div class="col-md-8">
            <form method="POST" action="/register">
              <div class="form-group">
                <label for="name" class="form-label"><%= t('pages.register.form.name').toUpperCase() %></label>
                <input type="text" class="form-control" id="name" name="name" required placeholder="Ej: Juan Pérez">
              </div>

              <div class="form-group">
                <label for="email" class="form-label"><%= t('pages.register.form.email').toUpperCase() %></label>
                <input type="email" class="form-control" id="email" name="email" required placeholder="Ej: d.cruz+test@salesforce.com">
                <small class="form-text text-muted">Cada registro debe tener un email único.</small>
              </div>
              
              <div class="form-group">
                <label class="form-label"><%= t('pages.register.form.interests').toUpperCase() %></label>
                <% brand.categories.forEach(category => { %>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="preferences" value="<%= category.id %>" id="<%= category.id %>">
                    <label class="form-check-label" for="<%= category.id %>"><%= category.label %></label>
                  </div>
                <% }); %>
              </div>
              
              <button type="submit" class="btn btn-primary btn-lg btn-block mt-4" style="background-color: #d81e05; border: none;">
                <%= t('pages.register.form.submit') %>
              </button>
            </form>

            <div class="text-center mt-3">
              <button type="button" id="autofillBtn" class="btn btn-danger btn-sm" style="font-size: 13px; padding: 10px 20px; background-color: #d81e05 !important; border: none !important; color: white !important;">
                <i class="fas fa-magic"></i> Rellenar automáticamente (Demo)
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const btn = document.getElementById('autofillBtn');
    if (btn) {
      btn.addEventListener('click', function() {
        console.log('Botón clickeado'); // Para verificar en la consola del navegador
        const names = ['Ricardo Blanco', 'Paula Pascual', 'Fernando Cruz', 'Elena Gomez', 'Roberto Moral'];
        const randomName = names[Math.floor(Math.random() * names.length)];
        
        // Formato: d.cruz+nombre1234@salesforce.com
        const alias = randomName.toLowerCase().replace(/\s+/g, '');
        const num = Math.floor(Math.random() * 90000) + 10000;
        const generatedEmail = `d.cruz+${alias}${num}@salesforce.com`;

        document.getElementById('name').value = randomName;
        document.getElementById('email').value = generatedEmail;

        // Marcar un interés al azar
        const checks = document.querySelectorAll('.form-check-input');
        if(checks.length > 0) {
            checks.forEach(c => c.checked = false);
            checks[Math.floor(Math.random() * checks.length)].checked = true;
        }
      });
    }
  });
</script>

<%- include('partials/footer') %>