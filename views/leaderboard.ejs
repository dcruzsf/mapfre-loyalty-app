<%- include('partials/header', {currentPage: 'leaderboard', member: member}) %>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/"><%= t('navigation.home') %></a></li>
    <li class="breadcrumb-item active"><%= t('pages.leaderboard.breadcrumb') %></li>
  </ol>
</nav>

<div class="page-header-space">
  <h1 class="page-title"><%= locale === 'es' ? 'Tu Engagement Score' : 'Your Engagement Score' %></h1>
  <p class="page-subtitle"><%= locale === 'es' ? 'Descubre tu nivel de compromiso y compite en el leaderboard' : 'Discover your engagement level and compete on the leaderboard' %></p>
</div>

<% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
  <div class="alert alert-danger">
    <i class="fas fa-exclamation-circle"></i> <%= errorMessage %>
  </div>
<% } %>

<% if (typeof successMessage !== 'undefined' && successMessage) { %>
  <div class="confirmation-message">
    <i class="fas fa-check-circle"></i> <%= successMessage %>
  </div>
<% } %>

<% if (typeof missingId !== 'undefined' && missingId) { %>
  <div class="alert alert-warning">
    <i class="fas fa-exclamation-triangle"></i> <strong><%= locale === 'es' ? 'Aviso:' : 'Notice:' %></strong> <%= locale === 'es' ? 'Tu cuenta no tiene un ID de Salesforce asignado.' : 'Your account does not have a Salesforce ID assigned.' %>
    <% if (useSalesforce) { %>
      <%= locale === 'es' ? 'Para participar en el leaderboard, debes registrarte con el modo Salesforce activado.' : 'To participate in the leaderboard, you must register with Salesforce mode enabled.' %>
    <% } else { %>
      <%= locale === 'es' ? 'El modo Salesforce está desactivado. Estás en modo demo.' : 'Salesforce mode is disabled. You are in demo mode.' %>
    <% } %>
  </div>
<% } %>

<%- include('partials/tier-progress', {member: member, locale: locale}) %>

<div class="leaderboard-container">
  <div class="row">
    <div class="col-md-6">
      <div class="score-display">
        <div class="score-circle">
          <div class="score-value"><%= Math.round(scorePreview.score) %></div>
          <div class="score-label"><%= t('units.points').toUpperCase() %></div>
        </div>
        <div class="engagement-level"><%= scorePreview.level %></div>
      </div>
    </div>
    
    <div class="col-md-6">
      <div class="score-details">
        <% const details = scorePreview.details; %>
        
        <!-- Logros -->
        <div class="score-category">
          <div class="score-category-label">
            <span class="score-category-name"><%= locale === 'es' ? 'Logros desbloqueados' : 'Unlocked achievements' %></span>
            <span class="score-category-value"><%= details.achievements.value %>/<%= details.achievements.maxValue %> (<%=  Math.round(details.achievements.percentage) %>%)</span>
          </div>
          <div class="score-progress-bar">
            <div class="score-progress-fill progress-achievements" data-width="<%= details.achievements.percentage %>"></div>
          </div>
        </div>
        
        <!-- Puntos de nivel -->
        <div class="score-category">
          <div class="score-category-label">
            <span class="score-category-name"><%= t('member.levelPoints') %></span>
            <span class="score-category-value"><%= details.levelPoints.value %> (<%= Math.round(details.levelPoints.percentage) %>%)</span>
          </div>
          <div class="score-progress-bar">
            <div class="score-progress-fill progress-levelPoints" data-width="<%= details.levelPoints.percentage %>"></div>
          </div>
        </div>
        
        <!-- Puntos de rewards -->
        <div class="score-category">
          <div class="score-category-label">
            <span class="score-category-name"><%= t('member.rewardPoints') %></span>
            <span class="score-category-value"><%= details.rewardPoints.value %> (<%= Math.round(details.rewardPoints.percentage) %>%)</span>
          </div>
          <div class="score-progress-bar">
            <div class="score-progress-fill progress-rewardPoints" data-width="<%= details.rewardPoints.percentage %>"></div>
          </div>
        </div>
        
        <!-- Nivel -->
        <div class="score-category">
          <div class="score-category-label">
            <span class="score-category-name"><%= locale === 'es' ? 'Nivel actual' : 'Current tier' %></span>
            <span class="score-category-value"><%= details.tier.value %> (<%= Math.round(details.tier.percentage) %>%)</span>
          </div>
          <div class="score-progress-bar">
            <div class="score-progress-fill progress-tier" data-width="<%= details.tier.percentage %>"></div>
          </div>
        </div>
        
        <!-- Saldo restante -->
        <div class="score-category">
          <div class="score-category-label">
            <span class="score-category-name"><%= locale === 'es' ? 'Saldo disponible' : 'Available balance' %></span>
            <span class="score-category-value"><%= details.balance.value.toFixed(2) %>€ (<%= Math.round(details.balance.percentage) %>%)</span>
          </div>
          <div class="score-progress-bar">
            <div class="score-progress-fill progress-balance" data-width="<%= details.balance.percentage %>"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <% if (!hasSubmitted) { %>
    <form method="POST" action="/leaderboard/submit" id="leaderboardForm">
      <button type="submit" class="submit-button" <%= (missingId && useSalesforce) ? 'disabled' : '' %>>
        <i class="fas fa-trophy"></i> <%= locale === 'es' ? 'Enviar al Leaderboard' : 'Submit to Leaderboard' %>
      </button>
      <% if (missingId && useSalesforce) { %>
        <p class="text-center text-muted mt-2">
          <%= locale === 'es' ? 'No puedes enviar tu puntuación sin un ID de Salesforce.' : 'You cannot submit your score without a Salesforce ID.' %>
        </p>
      <% } %>
    </form>
  <% } else { %>
    <div class="text-center mt-4">
      <p class="text-success">
        <i class="fas fa-check-circle"></i> 
        <%= locale === 'es' ? 'Ya has enviado tu puntuación al leaderboard' : 'You have already submitted your score to the leaderboard' %> 
        (<%= new Date(member.leaderboardSubmittedAt).toLocaleString() %>)
      </p>
    </div>
  <% } %>
</div>

<div class="leaderboard-explanation">
  <h4><%= locale === 'es' ? '¿Cómo se calcula tu Engagement Score?' : 'How is your Engagement Score calculated?' %></h4>
  <p><%= locale === 'es' ? 'Tu puntuación se basa en tu actividad e interacción con nuestra plataforma:' : 'Your score is based on your activity and interaction with our platform:' %></p>
  
  <ul>
    <li><strong><%= locale === 'es' ? 'Logros desbloqueados (40%):' : 'Unlocked achievements (40%):' %></strong> <%= locale === 'es' ? 'Cuantos más logros consigas, mayor será tu puntuación.' : 'The more achievements you unlock, the higher your score.' %></li>
    <li><strong><%= t('member.levelPoints') %> (25%):</strong> <%= locale === 'es' ? 'Los puntos de nivel que has acumulado.' : 'The level points you have accumulated.' %></li>
    <li><strong><%= t('member.rewardPoints') %> (15%):</strong> <%= locale === 'es' ? 'Los puntos disponibles para canjear por recompensas.' : 'The points available to redeem for rewards.' %></li>
    <li><strong><%= locale === 'es' ? 'Nivel alcanzado (15%):' : 'Tier reached (15%):' %></strong> <%= locale === 'es' ? 'Tu nivel actual (Bronze, Silver, Gold o Platinum).' : 'Your current tier (Bronze, Silver, Gold or Platinum).' %></li>
    <li><strong><%= locale === 'es' ? 'Saldo disponible (5%):' : 'Available balance (5%):' %></strong> <%= locale === 'es' ? 'Un bono por mantener un buen saldo.' : 'A bonus for maintaining a good balance.' %></li>
  </ul>
  
  <p class="mb-0"><%= locale === 'es' ? 'Tu puntuación se actualizará automáticamente a medida que interactúes con la plataforma. ¡Sigue participando para mejorar tu posición en el leaderboard!' : 'Your score will update automatically as you interact with the platform. Keep participating to improve your leaderboard position!' %></p>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Configurar todos los elementos con data-width (barras de progreso)
    const progressBars = document.querySelectorAll('[data-width]');
    progressBars.forEach(bar => {
      const width = bar.getAttribute('data-width');
      if (width) {
        bar.style.width = width + '%';
      }
    });
  });
</script>

<%- include('partials/footer') %>